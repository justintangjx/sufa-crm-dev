{
  "name": "sufa-crm-dev",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "oxlint .",
    "lint:strict": "oxlint --deny-warnings .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "eval:coach:deterministic": "vitest run src/lib/coachNotes.test.ts src/shared/coach-note-core.sync.test.ts src/evals/coach-notes/coachNotes.eval.test.ts src/evals/coach-notes/multi-turn.eval.test.ts",
    "eval:coach:live": "node scripts/eval-coach-live.mjs",
    "eval:coach:compare": "node scripts/eval-coach-compare.mjs",
    "e2e": "playwright test",
    "sync:coach-note-core": "node scripts/sync-coach-note-core.mjs",
    "check": "pnpm sync:coach-note-core && pnpm typecheck && pnpm lint && pnpm format:check && pnpm test"
  },
  "dependencies": {
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@supabase/supabase-js": "^2.108.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
