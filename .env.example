# Copy to .env.local and fill in values from your Supabase project settings.
# Vite only exposes variables prefixed with VITE_ to the client.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional. Leave false/omitted until Supabase migrations, the structure-coach-notes Edge
# Function, model secrets, and live eval checks are deployed. Mock mode and tests exercise
# the full Evaluation copilot without remote infrastructure.
VITE_ENABLE_COACH_LLM=false
