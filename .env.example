# Copy to .env.local and fill in values from your Supabase project settings.
# Vite only exposes variables prefixed with VITE_ to the client.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional. Leave false/omitted until Supabase migrations, the structure-coach-notes Edge
# Function, model secrets, and live eval checks are deployed. Mock mode and tests exercise
# the full Evaluation copilot without remote infrastructure.
VITE_ENABLE_COACH_LLM=false

# Hybrid demo: instant mock login (VITE_USE_MOCK=true) + real LLM for coach evaluations.
# Run supabase/seed-demo-coach.sql, deploy structure-coach-notes + demo-coach-session, then:
# VITE_USE_MOCK=true
# VITE_DEMO_COACH_LLM=true
# VITE_COACH_DEMO_GATE_TOKEN=your-public-demo-gate-token
# VITE_DEMO_COACH_LLM_ID_MAP={"c-sea":"c0000000-0000-4000-8000-000000000001","a-alice":"a0000000-0000-4000-8000-000000000001","a-ben":"a0000000-0000-4000-8000-000000000002","a-cara":"a0000000-0000-4000-8000-000000000003"}
